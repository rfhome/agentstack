generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  password        String?
  tier            String           @default("free") // "free" | "beta" | "premium"
  accounts        Account[]
  workouts        Session[]
  goals           Goal[]
  recommendations Recommendation[]
  agentLogs       AgentLog[]
  profile         UserProfile?
  wearables       WearableConnection[]
  createdAt       DateTime         @default(now())
}

model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  tier      String    @default("beta")  // tier granted on redemption
  maxUses   Int       @default(100)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id                Int              @id @default(autoincrement())
  userId            String?
  user              User?            @relation(fields: [userId], references: [id])
  date              DateTime         @default(now())
  cycleDay          Int?
  cycleNumber       Int?
  durationMinutes   Int?
  avgHeartRate      Int?
  cardioLoad        Int?
  activeZoneMinutes Int?
  rating            String?
  notes             String?
  exercises         Exercise[]
  cardioActivities  CardioActivity[]
  agentLogs         AgentLog[]
  recommendations   Recommendation[]
  wearableSnapshot  Json?
  images            Json?
  createdAt         DateTime         @default(now())
}

model Exercise {
  id        Int     @id @default(autoincrement())
  session   Session @relation(fields: [sessionId], references: [id])
  sessionId Int
  name      String
  sets      Int?
  reps      String?
  weights   String?
  weightLbs Float?
  notes     String?
}

model CardioActivity {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  session     Session  @relation(fields: [sessionId], references: [id])
  userId      String?
  tag         String   // "warmup" | "finisher" | "standalone"
  machine     String   // "treadmill" | "bike" | "rower" | "elliptical"
  durationMin Int?
  distanceMi  Float?
  calories    Int?
  avgHR       Int?
  maxHR       Int?
  notes       String?
  createdAt   DateTime @default(now())
}

model AgentLog {
  id        Int      @id @default(autoincrement())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])
  sessionId Int?
  agentName String
  model     String
  domain    String
  prompt    String
  response  String
  latencyMs Int?
  createdAt DateTime @default(now())
}

model Recommendation {
  id          Int      @id @default(autoincrement())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  session     Session? @relation(fields: [sessionId], references: [id])
  sessionId   Int?
  domain      String
  content     String
  nextActions Json
  createdAt   DateTime @default(now())
}

model Goal {
  id              Int       @id @default(autoincrement())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  exercise        String
  targetWeightLbs Float?
  targetReps      String?
  cycleNumber     Int?
  achieved        Boolean   @default(false)
  achievedAt      DateTime?
  createdAt       DateTime  @default(now())
}

model WearableConnection {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // "oura" | "fitbit"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

model UserProfile {
  id                 Int      @id @default(autoincrement())
  userId             String?  @unique
  user               User?    @relation(fields: [userId], references: [id])
  name               String   @default("")
  context            String   @default("")
  programConfig      Json?
  onboardingComplete Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}
